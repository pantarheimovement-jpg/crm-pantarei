  "whatsapp_greeting": "\u05e9\u05dc\u05d5\u05dd! \u05d0\u05e0\u05d9 \u05e1\u05d5\u05db\u05df \u05d4-AI \u05e9\u05dc Pantarhei CRM \ud83d\udc9c \u05d0\u05e0\u05d9 \u05db\u05d0\u05df \u05db\u05d3\u05d9 \u05dc\u05e2\u05d6\u05d5\u05e8 \u05dc\u05da \u05dc\u05e0\u05d4\u05dc \u05d0\u05ea \u05d4\u05e0\u05ea\u05d5\u05e0\u05d9\u05dd \u05e9\u05dc\u05da, \u05dc\u05e2\u05e0\u05d5\u05ea \u05e2\u05dc \u05e9\u05d0\u05dc\u05d5\u05ea, \u05d5\u05dc\u05d4\u05e1\u05d1\u05d9\u05e8 \u05e2\u05dc \u05d4\u05de\u05e2\u05e8\u05db\u05ea. \u05de\u05d4 \u05ea\u05e8\u05e6\u05d9 \u05dc\u05e2\u05e9\u05d5\u05ea?",
